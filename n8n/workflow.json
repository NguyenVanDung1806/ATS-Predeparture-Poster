{
  "name": "ATS Pre-departure Poster",
  "nodes": [
    {
      "id": "node-webhook",
      "name": "Webhook",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2,
      "position": [240, 300],
      "parameters": {
        "httpMethod": "POST",
        "path": "predeparture",
        "responseMode": "onReceived",
        "responseCode": 202,
        "options": {}
      },
      "webhookId": "ats-predeparture"
    },

    {
      "id": "node-normalize",
      "name": "Code: Normalize + Build Prompt",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [460, 300],
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const item = $input.item;\nconst body = item.json.body || {};\n\nconst clean = (value, max = 200) =>\n  String(value || '')\n    .trim()\n    .replace(/\\s+/g, ' ')\n    .slice(0, max);\n\nconst name         = clean(body.ten, 80);\nconst email        = clean(body.email, 120).toLowerCase();\nconst university   = clean(body.truong, 120);\nconst country      = clean(body.quocgia, 60);\nconst interests    = clean(body.soThich, 180) || 'học tập và khám phá văn hóa mới';\nconst consent      = body.consent === 'on' || body.consent === 'true' || body.consent === true;\nconst eventId      = clean(body.eventId, 80);\nconst submissionId = clean(body.submissionId, 80);\nconst shortName    = name ? name.split(' ').pop() : 'bạn';\n\nconst prompt = `Create a polished study-abroad celebration poster for ATS Education.\n\nUse the uploaded photo as the main subject. Preserve the student's face, identity, age impression, and natural appearance. Do not invent a different person.\n\nStudent details:\n- Name: ${name}\n- University: ${university}\n- Destination country: ${country}\n- Personal interests: ${interests}\n\nDesign requirements:\n- Format: vertical social poster, 1024x1536.\n- Visual style: modern, energetic, premium education-event design.\n- Brand colors: navy blue #003087, gold #FFB81C, white accents.\n- Main subject: the uploaded student photo, smiling or confident, centered.\n- Background: recognizable but tasteful scenery or landmark associated with ${country}.\n- Text overlay: \"${name}\" as the primary title.\n- Text overlay: \"${university}\" as secondary text.\n- Branding: subtle \"ATS Education\" text/logo area in the top-right.\n- Decorative elements: graduation cap, stars, travel/study-abroad accents, light confetti.\n- Keep all text legible. Avoid misspelling the student's name and university.\n- No extra people, no fake logos of the university, no distorted face, no inappropriate content.`.trim();\n\nconst congratsByCountry = {\n  Australia:       `Chúc ${shortName} có một hành trình tuyệt vời tại Australia! ATS Education luôn đồng hành cùng bạn trên chặng đường mới.`,\n  Canada:          `Chúc ${shortName} bắt đầu hành trình tại Canada với thật nhiều năng lượng, trải nghiệm đẹp và cơ hội mới.`,\n  'United States': `Chúc ${shortName} chinh phục hành trình học tập tại Mỹ thật trọn vẹn. ATS Education tin bạn sẽ tạo nên nhiều dấu ấn đáng tự hào.`,\n  'United Kingdom':`Chúc ${shortName} có những năm tháng học tập đáng nhớ tại Vương quốc Anh. ATS Education luôn sẵn sàng đồng hành khi bạn cần.`,\n  'New Zealand':   `Chúc ${shortName} tận hưởng hành trình học tập tại New Zealand với thật nhiều trải nghiệm đáng nhớ.`\n};\n\nconst congratsMessage =\n  congratsByCountry[country] ||\n  `Chúc ${shortName} có một hành trình du học thật ý nghĩa. ATS Education tự hào đồng hành cùng ước mơ của bạn.`;\n\nreturn {\n  json: {\n    ...item.json,\n    name,\n    email,\n    university,\n    country,\n    interests,\n    consent,\n    eventId,\n    submissionId,\n    prompt,\n    congratsMessage,\n    status: 'NORMALIZED'\n  },\n  binary: item.binary\n};"
      }
    },

    {
      "id": "node-validate",
      "name": "IF: Validate Required Fields",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [680, 300],
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": false,
            "leftValue": "",
            "typeValidation": "loose"
          },
          "combinator": "and",
          "conditions": [
            {
              "id": "cond-name",
              "leftValue": "={{ $json.name }}",
              "rightValue": "",
              "operator": {
                "type": "string",
                "operation": "notEmpty",
                "singleValue": true
              }
            },
            {
              "id": "cond-email",
              "leftValue": "={{ $json.email }}",
              "rightValue": "",
              "operator": {
                "type": "string",
                "operation": "notEmpty",
                "singleValue": true
              }
            },
            {
              "id": "cond-university",
              "leftValue": "={{ $json.university }}",
              "rightValue": "",
              "operator": {
                "type": "string",
                "operation": "notEmpty",
                "singleValue": true
              }
            },
            {
              "id": "cond-country",
              "leftValue": "={{ $json.country }}",
              "rightValue": "",
              "operator": {
                "type": "string",
                "operation": "notEmpty",
                "singleValue": true
              }
            },
            {
              "id": "cond-consent",
              "leftValue": "={{ $json.consent }}",
              "rightValue": true,
              "operator": { "type": "boolean", "operation": "equals" }
            },
            {
              "id": "cond-eventid",
              "leftValue": "={{ $json.eventId }}",
              "rightValue": "",
              "operator": {
                "type": "string",
                "operation": "notEmpty",
                "singleValue": true
              }
            },
            {
              "id": "cond-submissionid",
              "leftValue": "={{ $json.submissionId }}",
              "rightValue": "",
              "operator": {
                "type": "string",
                "operation": "notEmpty",
                "singleValue": true
              }
            },
            {
              "id": "cond-file",
              "leftValue": "={{ $binary.anhCuaBan !== undefined }}",
              "rightValue": true,
              "operator": { "type": "boolean", "operation": "equals" }
            }
          ]
        }
      }
    },

