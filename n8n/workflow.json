    {
      "id": "node-check-duplicate",
      "name": "Sheets: Check Duplicate",
      "type": "n8n-nodes-base.googleSheets",
      "typeVersion": 4,
      "position": [900, 300],
      "alwaysOutputData": true,
      "parameters": {
        "operation": "read",
        "documentId": {
          "__rl": true,
          "value": "17qDRUMehf5PoNwl1tBMHDI22ny0pa4CT7PjmxBMmkmE",
          "mode": "id"
        },
        "sheetName": {
          "__rl": true,
          "value": "Log",
          "mode": "name"
        },
        "filtersUI": {
          "values": [
            {
              "lookupColumn": "Submission ID",
              "lookupValue": "={{ $json.submissionId }}"
            }
          ]
        },
        "options": {
          "returnAllMatches": true
        }
      },
      "credentials": {
        "googleSheetsOAuth2Api": {
          "id": "google-sheets-cred",
          "name": "Google Sheets"
        }
      }
    },

    {
      "id": "node-code-check-dup",
      "name": "Code: Is Duplicate?",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1100, 300],
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "const allItems = $input.all();\n\n// Tìm submission đã COMPLETED hoặc email đã gửi\nconst found = allItems.find(item =>\n  item.json?.['Status'] === 'COMPLETED' ||\n  item.json?.['Email Sent'] === 'TRUE'\n);\n\n// Lấy context từ item đầu tiên có dữ liệu của submission này\n// (item.json có thể là row từ Sheets, hoặc empty nếu không tìm thấy)\nconst ctx = allItems[0]?.json || {};\n\nreturn [{\n  json: {\n    ...ctx,\n    isDuplicate: !!found\n  },\n  binary: allItems[0]?.binary || {}\n}];"
      }
    },

    {
      "id": "node-if-duplicate",
      "name": "IF: Is Duplicate",
      "type": "n8n-nodes-base.if",
