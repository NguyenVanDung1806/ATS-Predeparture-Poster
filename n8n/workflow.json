          "combinator": "and",
          "conditions": [
            {
              "id": "cond-dup",
              "leftValue": "={{ $json.isDuplicate }}",
              "rightValue": true,
              "operator": { "type": "boolean", "operation": "equals" }
            }
          ]
        }
      }
